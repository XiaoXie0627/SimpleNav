---
---

<footer class="footer">
  <div class="footer__quote" id="daily-quote">
    <p>加载中...</p>
  </div>
  <div class="footer__info">
    <span>Powered by <a href="https://astro.build" target="_blank">Astro</a></span>
    <span>•</span>
    <span>FastNav v2.0.0</span>
  </div>
</footer>

<style>
  .footer {
    position: fixed;
    bottom: 0;
    left: 240px;
    right: 0;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface-variant);
    border-top: 1px solid var(--outline-variant);
    z-index: 100;
  }

  .footer__quote {
    flex: 1;
    text-align: center;
    padding: 0 24px;
    font-size: 14px;
    font-style: italic;
    color: var(--on-surface-variant);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .footer__info {
    display: flex;
    gap: 8px;
    padding-right: 16px;
    font-size: 12px;
    color: var(--on-surface-variant);
  }

  .footer__info a {
    color: var(--primary);
    text-decoration: none;
  }

  .footer__info a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .footer {
      left: 0;
    }
  }
</style>

<script>
  import type { DailyQuoteConfig } from '../../types'
  
  // 每日一言
  async function loadDailyQuote() {
    const quoteEl = document.getElementById('daily-quote')?.querySelector('p')
    if (!quoteEl) return
    
    try {
      const response = await fetch('/api/site-config')
      if (response.ok) {
        const result = await response.json()
        if (result.success && result.data?.dailyQuote?.enabled) {
          const config: DailyQuoteConfig = result.data.dailyQuote
          const quotes = config.quotes.filter(q => q.trim())
          
          if (quotes.length > 0) {
            let index = 0
            
            switch (config.displayMode) {
              case 'random':
                index = Math.floor(Math.random() * quotes.length)
                break
              case 'sequential':
                index = new Date().getDate() % quotes.length
                break
              case 'fixed':
              default:
                index = 0
                break
            }
            
            quoteEl.textContent = quotes[index]
          }
        }
      }
    } catch {
      quoteEl.textContent = '生活不止眼前的代码，还有诗和远方'
    }
  }
  
  loadDailyQuote()
</script>

---
import type { NavigationItem } from '../../types'

interface Props {
  categories: NavigationItem[]
  activeCategory?: string
}

const { categories, activeCategory } = Astro.props
---

<aside class="sidebar">
  <div class="sidebar__header">
    <a href="/" class="sidebar__logo">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      <span>FastNav</span>
    </a>
  </div>
  
  <div class="sidebar__search">
    <input 
      type="text" 
      id="nav-search-input"
      placeholder="搜索导航项目..." 
      class="sidebar__search-input"
    />
  </div>
  
  <nav class="sidebar__nav">
    <div class="sidebar__section-title">分类</div>
    <ul class="sidebar__categories" id="sidebar-categories">
      {categories.map((category) => (
        <li>
          <a 
            href={`/category/${category.id}`}
            class={`sidebar__category-item ${activeCategory === category.id ? 'active' : ''}`}
            data-category-id={category.id}
          >
            <span class="sidebar__category-icon">
              {category.icon ? (
                <img src={category.icon} alt="" width="16" height="16" />
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                </svg>
              )}
            </span>
            <span class="sidebar__category-name">{category.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
  
  <div class="sidebar__footer">
    <button id="theme-toggle-btn" class="sidebar__footer-btn" title="切换主题">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
    </button>
    <a href="/admin" class="sidebar__footer-btn" title="管理后台">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="3"></circle>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
      </svg>
    </a>
  </div>
</aside>

<style>
  .sidebar {
    width: 240px;
    height: 100vh;
    position: fixed;
    left: 0;
    top: 0;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-right: 1px solid var(--outline-variant);
    padding: 16px;
    overflow-y: auto;
  }

  .sidebar__header {
    margin-bottom: 16px;
  }

  .sidebar__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 18px;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
  }

  .sidebar__search {
    margin-bottom: 16px;
  }

  .sidebar__search-input {
    width: 100%;
    height: 40px;
    padding: 8px 12px;
    border: 1px solid var(--outline-variant);
    border-radius: 8px;
    background: var(--surface);
    font-size: 14px;
    color: var(--on-surface);
  }

  .sidebar__search-input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 2px var(--primary-container);
    outline: none;
  }

  .sidebar__search-input::placeholder {
    color: var(--on-surface-variant);
  }

  .sidebar__nav {
    flex: 1;
    overflow-y: auto;
  }

  .sidebar__section-title {
    font-size: 12px;
    font-weight: 500;
    color: var(--on-surface-variant);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
    padding: 0 8px;
  }

  .sidebar__categories {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar__category-item {
    display: flex;
    align-items: center;
    gap: 12px;
    height: 40px;
    padding: 0 12px;
    border-radius: 8px;
    color: var(--on-surface);
    text-decoration: none;
    font-size: 14px;
    transition: background 0.2s ease;
  }

  .sidebar__category-item:hover {
    background: var(--surface-container);
  }

  .sidebar__category-item.active {
    background: var(--primary-container);
    color: var(--on-primary-container);
  }

  .sidebar__category-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sidebar__category-icon img {
    width: 16px;
    height: 16px;
    border-radius: 4px;
  }

  .sidebar__category-name {
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sidebar__footer {
    display: flex;
    gap: 8px;
    padding-top: 16px;
    border-top: 1px solid var(--outline-variant);
  }

  .sidebar__footer-btn {
    flex: 1;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: transparent;
    color: var(--on-surface-variant);
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
    text-decoration: none;
  }

  .sidebar__footer-btn:hover {
    background: var(--surface-container);
    color: var(--on-surface);
  }

  @media (max-width: 768px) {
    .sidebar {
      transform: translateX(-100%);
      transition: transform 0.3s ease;
    }

    .sidebar.open {
      transform: translateX(0);
    }
  }
</style>

<script>
  import { initTheme, toggleTheme } from '../../stores/theme'
  
  initTheme()
  
  document.getElementById('theme-toggle-btn')?.addEventListener('click', toggleTheme)
</script>

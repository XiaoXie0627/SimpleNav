---
import type { NavigationItem } from '../../types'

interface Props {
  categories: NavigationItem[]
  activeCategory?: string
}

const { categories, activeCategory } = Astro.props
---

<aside class="sidebar">
  <div class="sidebar__header">
    <a href="/" class="sidebar__logo">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      <span>FastNav</span>
    </a>
  </div>

  <div class="sidebar__search">
    <input
      type="text"
      id="nav-search-input"
      placeholder="搜索导航项目..."
      class="sidebar__search-input"
    />
  </div>

  <nav class="sidebar__nav">
    <ul class="sidebar__categories" id="sidebar-categories">
      {
        categories.map((category) => (
          <li class="sidebar__category-wrapper">
            <div
              class={`sidebar__category-item ${activeCategory === category.id ? 'active' : ''} ${category.subCategories?.length ? 'has-subcategories' : ''}`}
              data-category-id={category.id}
            >
              <span class="sidebar__category-icon">
                {category.icon ? (
                  <img src={category.icon} alt="" width="16" height="16" />
                ) : (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                  </svg>
                )}
              </span>
              <a href={`/category/${category.id}`} class="sidebar__category-name">
                {category.title}
              </a>
              {category.subCategories?.length ? (
                <button class="sidebar__expand-btn" data-expand={category.id}>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <polyline points="6 9 12 15 18 9" />
                  </svg>
                </button>
              ) : null}
            </div>
            {category.subCategories?.length ? (
              <ul class="sidebar__subcategories" id={`subcategories-${category.id}`}>
                {category.subCategories.map((sub) => (
                  <li>
                    <a
                      href={`/category/${category.id}#sub-${sub.id}`}
                      class="sidebar__subcategory-item"
                      data-subcategory-id={sub.id}
                    >
                      {sub.title}
                    </a>
                  </li>
                ))}
              </ul>
            ) : null}
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<style>
  .sidebar {
    width: 240px;
    height: 100vh;
    position: fixed;
    left: 0;
    top: 0;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border-right: 1px solid var(--outline-variant);
    padding: 16px;
    overflow-y: auto;
  }

  .sidebar__header {
    margin-bottom: 16px;
  }

  .sidebar__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 18px;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
  }

  .sidebar__search {
    margin-bottom: 16px;
  }

  .sidebar__search-input {
    width: 100%;
    height: 40px;
    padding: 8px 12px;
    border: 1px solid var(--outline-variant);
    border-radius: 8px;
    background: var(--surface);
    font-size: 14px;
    color: var(--on-surface);
  }

  .sidebar__search-input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 2px var(--primary-container);
    outline: none;
  }

  .sidebar__search-input::placeholder {
    color: var(--on-surface-variant);
  }

  .sidebar__nav {
    flex: 1;
    overflow-y: auto;
  }

  .sidebar__categories {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar__category-wrapper {
    margin-bottom: 4px;
  }

  .sidebar__category-item {
    display: flex;
    align-items: center;
    gap: 12px;
    height: 44px;
    padding: 0 12px;
    border-radius: 10px;
    color: var(--on-surface);
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    background: var(--surface-container);
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .sidebar__category-item:hover {
    background: var(--surface-container-high);
    transform: translateX(4px);
  }

  .sidebar__category-item.active {
    background: var(--primary-container);
    color: var(--on-primary-container);
  }

  .sidebar__category-item.has-subcategories {
    cursor: pointer;
  }

  .sidebar__category-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sidebar__category-icon img {
    width: 18px;
    height: 18px;
    border-radius: 4px;
  }

  .sidebar__category-name {
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: inherit;
    text-decoration: none;
  }

  .sidebar__expand-btn {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--on-surface-variant);
    padding: 0;
    transition: transform 0.2s ease;
  }

  .sidebar__expand-btn:hover {
    color: var(--on-surface);
  }

  .sidebar__expand-btn.expanded {
    transform: rotate(180deg);
  }

  .sidebar__subcategories {
    list-style: none;
    margin: 0;
    padding: 4px 0 8px 40px;
    display: none;
  }

  .sidebar__subcategories.expanded {
    display: block;
  }

  .sidebar__subcategory-item {
    display: flex;
    align-items: center;
    height: 32px;
    padding: 0 12px;
    border-radius: 6px;
    color: var(--on-surface-variant);
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  .sidebar__subcategory-item:hover {
    background: var(--surface-container);
    color: var(--on-surface);
  }

  @media (max-width: 768px) {
    .sidebar {
      transform: translateX(-100%);
      transition: transform 0.3s ease;
    }

    .sidebar.open {
      transform: translateX(0);
    }
  }
</style>

<script>
  import { initTheme } from '../../stores/theme'

  initTheme()

  document.querySelectorAll('.sidebar__expand-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault()
      const categoryId = btn.getAttribute('data-expand')
      const subcategories = document.getElementById(`subcategories-${categoryId}`)
      const expandBtn = btn as HTMLElement

      if (subcategories && expandBtn) {
        subcategories.classList.toggle('expanded')
        expandBtn.classList.toggle('expanded')
      }
    })
  })
</script>
